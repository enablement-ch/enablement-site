---
interface Props {
  eyebrow?: string;
  headline: string;
  lead?: string;
  bullets: string[];
  ctaLabel?: string;
  ctaHref?: string;
  reverse?: boolean;
}

const {
  eyebrow = "",
  headline,
  lead = "",
  bullets,
  ctaLabel = "",
  ctaHref = "",
  reverse = false,
} = Astro.props;
---

<div class:list={["pain-block", reverse && "reverse"]}>
  <div class="pain-text">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h3>{headline}</h3>
    {lead && <p class="pain-lead">{lead}</p>}
    <ul class="pain-bullets">
      {bullets.map((b) => <li>{b}</li>)}
    </ul>
    {ctaLabel && (
      <a href={ctaHref} class="btn btn-tertiary">
        {ctaLabel} <span class="arrow">→</span>
      </a>
    )}
  </div>
  <div class="pain-visual">
    <slot />
  </div>
</div>
---
interface Props {
  index: string; // "A", "B", "C"
  eyebrow: string; // "NO OUTBOUND"
  headline: string; // "You don't have outbound. Or what you have is broken."
  pain: string; // Pain articulation paragraph
  solution: string; // Solution paragraph
  ctaLabel?: string; // Default: "See this built for [company]"
  ctaHref?: string;
  reverse?: boolean; // Flip text/visual sides
}

const {
  index,
  eyebrow,
  headline,
  pain,
  solution,
  ctaLabel = "See this in action",
  ctaHref = "/case-studies",
  reverse = false,
} = Astro.props;
---

<div class:list={["pain-block", reverse && "reverse"]}>
  <div class="pain-text">
    <span class="eyebrow"
      ><span class="num">{index}</span><span class="sep">/</span>
      {eyebrow}</span
    >
    <h3>{headline}</h3>
    <p class="pain-body">{pain}</p>
    <p class="pain-body">{solution}</p>
    <a href={ctaHref} class="btn btn-tertiary">
      {ctaLabel} <span class="arrow">→</span>
    </a>
  </div>
  <div class="pain-visual">
    <slot />
  </div>
</div>
---
interface Props {
  eyebrow: string;
  headline: string; // The capability statement (Pierri H3)
  lead: string; // One-line lead-in below the H3
  bullets: string[]; // 2-3 feature bullets
  ctaLabel?: string;
  ctaHref?: string;
  reverse?: boolean; // Flip text/visual sides
}

const {
  eyebrow,
  headline,
  lead,
  bullets,
  ctaLabel = "See this in action",
  ctaHref = "/case-studies",
  reverse = false,
} = Astro.props;
---

<div class:list={["pain-block", reverse && "reverse"]}>
  <div class="pain-text">
    <span class="eyebrow">{eyebrow}</span>
    <h3>{headline}</h3>
    <p class="pain-lead">{lead}</p>
    <ul class="pain-bullets">
      {bullets.map((b) => <li>{b}</li>)}
    </ul>
    <a href={ctaHref} class="btn btn-tertiary">
      {ctaLabel} <span class="arrow">→</span>
    </a>
  </div>
  <div class="pain-visual">
    <slot />
  </div>
</div>
---
interface Props {
  eyebrow?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  videoLabel?: string;
  /** Rotating phrases after "Turn your tools into". First entry is the static fallback. */
  rotatingWords?: string[];
}

const {
  eyebrow = "GTM Engineering for B2B tech companies above $1m ARR",
  primaryHref = "/book",
  primaryLabel = "Schedule meeting",
  secondaryHref = "/case-studies",
  secondaryLabel = "See client work",
  videoLabel = "Watch · 3 min",
  rotatingWords = [
    "a GTM System",
    "an Allbound Engine",
    "Pipeline",
    "Revenue Growth",
  ],
} = Astro.props;
---

<header class="hero">
  <div class="container">
    <div class="hero-inner">
      <span class="eyebrow"
        ><span class="num">↳</span><span class="sep">/</span> {eyebrow}</span
      >
      <h1 class="display">
        Turn your tools into<br />
        <span
          class="italic-accent rotating-word"
          data-words={JSON.stringify(rotatingWords)}>{rotatingWords[0]}</span
        >
      </h1>
      <p class="lead hero-lead">
        Your fractional GTM engineering team. We turn your tools into outbound,
        inbound, and RevOps systems that work as one.
      </p>
      <div class="hero-actions">
        <a href={primaryHref} class="btn btn-accent btn-md">{primaryLabel}</a>
        <a href={secondaryHref} class="btn btn-tertiary"
          >{secondaryLabel} <span class="arrow">→</span></a
        >
      </div>
    </div>
  </div>

  <!-- VSL frame under the headline -->
  <div class="hero-visual">
    <div class="hero-visual-frame" aria-label="Intro video">
      <div class="hero-visual-play">
        <button class="play-btn" aria-label="Play intro video">
          <svg viewBox="0 0 24 24" fill="currentColor"
            ><path d="M8 5v14l11-7z"></path></svg
          >
        </button>
        <div class="label">{videoLabel}</div>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    if (
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches
    )
      return;
    document.querySelectorAll(".rotating-word").forEach((el) => {
      let words = [];
      try {
        words = JSON.parse(el.dataset.words || "[]");
      } catch (e) {
        return;
      }
      if (!words || words.length <= 1) return;
      let i = 0;
      setInterval(() => {
        el.classList.add("fading");
        setTimeout(() => {
          i = (i + 1) % words.length;
          el.textContent = words[i];
          el.classList.remove("fading");
        }, 300);
      }, 3500);
    });
  })();
</script>
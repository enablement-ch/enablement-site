---
interface Props {
  eyebrow?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  videoLabel?: string;
}

const {
  eyebrow = "Fractional GTM engineering · DACH",
  primaryHref = "/book",
  primaryLabel = "Schedule meeting",
  secondaryHref = "/case-studies",
  secondaryLabel = "See client work",
  videoLabel = "Watch · 3 min · What we do",
} = Astro.props;
---

<header class="hero">
  <div class="container">
    <div class="hero-inner">
      <span class="eyebrow"
        ><span class="num">↳</span><span class="sep">/</span> {eyebrow}</span
      >
      <h1 class="display">
        Scale your pipeline,<br />
        <span class="italic-accent">not your headcount.</span>
      </h1>
      <p class="lead hero-lead">
        We build the outbound systems B2B teams haven't been able to build for
        themselves. Brief to production in 4–6 weeks. You own it, or we run it.
      </p>
      <div class="hero-actions">
        <a href={primaryHref} class="btn btn-accent btn-md">{primaryLabel}</a>
        <a href={secondaryHref} class="btn btn-tertiary"
          >{secondaryLabel} <span class="arrow">→</span></a
        >
      </div>
    </div>
  </div>

  <!-- VSL frame under the headline -->
  <div class="hero-visual">
    <div class="hero-visual-frame" aria-label="Intro video">
      <div class="hero-visual-play">
        <button class="play-btn" aria-label="Play intro video">
          <svg viewBox="0 0 24 24" fill="currentColor"
            ><path d="M8 5v14l11-7z"></path></svg
          >
        </button>
        <div class="label">{videoLabel}</div>
      </div>
    </div>
  </div>
</header>
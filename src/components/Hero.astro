---
interface Props {
  eyebrow?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  videoLabel?: string;
  /** Rotating phrases after "Turn your tools into". First entry is the static fallback. */
  rotatingWords?: string[];
  /** Vimeo URL (any format) for the hero VSL. Loaded on click. */
  vimeoUrl?: string;
}

const {
  eyebrow = "GTM Engineering for B2B tech companies above $1m ARR",
  primaryHref = "/book",
  primaryLabel = "Schedule meeting",
  secondaryHref = "/case-studies",
  secondaryLabel = "See client work",
  videoLabel = "Watch · 3 min",
  rotatingWords = [
    "a GTM System",
    "an Allbound Engine",
    "Pipeline",
    "Revenue Growth",
  ],
  vimeoUrl = "https://vimeo.com/1054121771/bbe92f66a3",
} = Astro.props;

// Parse Vimeo URL: vimeo.com/{id}/{hash} or vimeo.com/{id}
const vimeoMatch = vimeoUrl?.match(/vimeo\.com\/(\d+)(?:\/([a-zA-Z0-9]+))?/);
const vimeoId = vimeoMatch?.[1];
const vimeoHash = vimeoMatch?.[2];

// Fetch the Vimeo thumbnail at build time so the facade renders a preview image
// instead of an empty card.
let vimeoThumb = "";
if (vimeoUrl) {
  try {
    const res = await fetch(
      `https://vimeo.com/api/oembed.json?url=${encodeURIComponent(vimeoUrl)}`
    );
    if (res.ok) {
      const data = await res.json();
      vimeoThumb = (data.thumbnail_url || "").replace(/_\d+x\d+/, "_1280");
    }
  } catch (e) {
    // graceful fallback - facade renders without thumbnail
  }
}
---

<header class="hero">
  <div class="container">
    <div class="hero-inner">
      <span class="eyebrow"
        >{eyebrow}</span
      >
      <h1 class="display">
        Turn your tools into<br />
        <span
          class="italic-accent rotating-word"
          data-words={JSON.stringify(rotatingWords)}>{rotatingWords[0]}</span
        >
      </h1>
      <p class="lead hero-lead">
        Your fractional GTM engineering team. We turn your tools into outbound,
        inbound, and RevOps systems that work as one.
      </p>
    </div>
  </div>

  <!-- VSL frame under the headline -->
  <div class="hero-visual">
    <div
      class:list={["hero-visual-frame", "vimeo-facade", vimeoThumb && "has-thumb"]}
      aria-label="Intro video"
      data-vimeo-id={vimeoId}
      data-vimeo-hash={vimeoHash}
      style={vimeoThumb
        ? `background-image: url(${vimeoThumb}); background-size: cover; background-position: center;`
        : undefined}
    >
      <div class="hero-visual-play">
        <button class="play-btn" aria-label="Play intro video">
          <svg viewBox="0 0 24 24" fill="currentColor"
            ><path d="M8 5v14l11-7z"></path></svg
          >
        </button>
        <div class="label">{videoLabel}</div>
      </div>
    </div>
  </div>

  <!-- CTAs below the video -->
  <div class="container">
    <div class="hero-actions hero-actions-below">
      <a href={primaryHref} class="btn btn-accent btn-md">{primaryLabel}</a>
      <a href={secondaryHref} class="btn btn-tertiary"
        >{secondaryLabel} <span class="arrow">→</span></a
      >
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    if (
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches
    )
      return;
    document.querySelectorAll(".rotating-word").forEach((el) => {
      let words = [];
      try {
        words = JSON.parse(el.dataset.words || "[]");
      } catch (e) {
        return;
      }
      if (!words || words.length <= 1) return;
      let i = 0;
      setInterval(() => {
        el.classList.add("fading");
        setTimeout(() => {
          i = (i + 1) % words.length;
          el.textContent = words[i];
          el.classList.remove("fading");
        }, 300);
      }, 3500);
    });
  })();
</script>
---
// Disabled for soft launch — restore { href: "/case-studies", label: "Clients" } when case studies relaunch.
const links: { href: string; label: string }[] = [];

interface Props {
  /** Override the nav CTA per page (e.g. anchor to an on-page apply form). */
  ctaHref?: string;
  ctaLabel?: string;
}

const { ctaHref = "/book", ctaLabel = "Schedule meeting" } = Astro.props;
---

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Enablement.ch">
      <img src="/logo-black.svg" alt="" class="logo-img logo-img-light" />
      <img src="/logo-white.svg" alt="" class="logo-img logo-img-dark" />
    </a>
    <div class="nav-menu">
      {links.map(({ href, label }) => <a href={href}>{label}</a>)}
    </div>
    <div class="nav-actions">
      <button
        class="theme-toggle"
        aria-label="Toggle theme"
        onclick="toggleTheme()"
      >
        <svg
          class="icon-moon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg
        >
        <svg
          class="icon-sun"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="12" cy="12" r="4"></circle><path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
          ></path></svg
        >
      </button>
      <a href={ctaHref} class="btn btn-accent btn-sm">{ctaLabel}</a>
    </div>
  </div>
</nav>

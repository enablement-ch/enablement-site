---
interface LogoCell {
  name: string;
  /** Path to logo file shown in LIGHT mode. */
  logo?: string;
  /** Optional path to logo file shown in DARK mode. If provided, both files
   * are rendered (one hidden by CSS based on data-theme) and the filter/blend
   * treatment is skipped for the theme-matched file. */
  logoDark?: string;
  caseStudy?: string;
  /** Override default 28px render height. Use to dial down visually heavy
   * wordmarks that read as over-dominant next to lighter-stroke peers. */
  height?: number;
}

interface Props {
  label?: string;
  logos?: LogoCell[];
}

const {
  label = "Trusted by over 100 GTM teams",
  logos = [
    { name: "Scrypt", logo: "/logos/scrypt-orange.png", logoDark: "/logos/scrypt-orange.png" }, // caseStudy: "/case-studies/scrypt" — restore on case-studies relaunch. Single brand-orange file used in both themes.
    { name: "HubSpot", logo: "/logos/hubspot-orange.png", logoDark: "/logos/hubspot-white.png" },
    { name: "Skribble", logo: "/logos/skribble-black.png", logoDark: "/logos/skribble-white.png", height: 24 },
    { name: "Strategyzer", logo: "/logos/strategyzer-black.png", logoDark: "/logos/strategyzer-white.png", height: 22 },
    { name: "Ohalo", logo: "/logos/ohalo-blue.webp", logoDark: "/logos/ohalo-white.png" }, // caseStudy: "/case-studies/ohalo" — restore on case-studies relaunch
    { name: "Bound", logo: "/logos/bound-black.avif", logoDark: "/logos/bound-white.avif" },
    { name: "Hy.co", logo: "/logos/hyco-black.png", logoDark: "/logos/hyco-white.png" },
    { name: "Lipdub", logo: "/logos/lipdub-black.png", logoDark: "/logos/lipdub-white.avif" },
    { name: "Adthena", logo: "/logos/adthena-black.png", logoDark: "/logos/adthena-white.png" },
    { name: "Emlen", logo: "/logos/emlen-black.png", logoDark: "/logos/emlen-white.png" },
    { name: "Leostream", logo: "/logos/leostream-black.png", logoDark: "/logos/leostream-white.png" },
    { name: "Orca", logo: "/logos/orca-black.png", logoDark: "/logos/orca-white.png", height: 22 },
    { name: "Mybites", logo: "/logos/mybites.svg", logoDark: "/logos/mybites-white.png" },
    { name: "Sysdyne", logo: "/logos/sysdyne-black.png", logoDark: "/logos/sysdyne-white.png" },
    { name: "Trawa", logo: "/logos/trawa-black.png", logoDark: "/logos/trawa-white.png", height: 24 },
    { name: "Blueprint", logo: "/logos/blueprint-black.png", logoDark: "/logos/blueprint-white.png" },
    { name: "Skillfit", logo: "/logos/skillfit-darkblue.png", logoDark: "/logos/skillfit-white.png", height: 24 },
    { name: "Condenzero", logo: "/logos/condenzero-black.png", logoDark: "/logos/condenzero-white.png" },
    { name: "Ekipa", logo: "/logos/ekipa-black.png", logoDark: "/logos/ekipa-white.png" },
    { name: "Slabstack", logo: "/logos/slabstack-black.png", logoDark: "/logos/slabstack-white.png" },
    { name: "Dualentry", logo: "/logos/dualentry-black.png", logoDark: "/logos/dualentry-white.png" },
    { name: "Workleap", logo: "/logos/workleap-black.png", logoDark: "/logos/workleap-white.png" },
  ],
} = Astro.props;

const trackLogos = [...logos, ...logos];
---

<section class="marquee-section" aria-label="Clients">
  <div class="marquee-row">
    <div class="marquee-label">{label}</div>
    <div class="marquee">
      <div class="marquee-track">
        {
          trackLogos.map((logo, idx) => {
            const hasBoth = logo.logo && logo.logoDark;
            const heightStyle = logo.height ? `height:${logo.height}px` : undefined;
            const inner = (
              <>
                {logo.logo && (
                  <img
                    class:list={[
                      "logo-img",
                      hasBoth && "logo-img-light",
                      hasBoth && "native",
                    ]}
                    src={logo.logo}
                    alt={logo.name}
                    loading="lazy"
                    style={heightStyle}
                  />
                )}
                {logo.logoDark && (
                  <img
                    class:list={["logo-img", "logo-img-dark", "native"]}
                    src={logo.logoDark}
                    alt={logo.name}
                    loading="lazy"
                    style={heightStyle}
                  />
                )}
                {!logo.logo && !logo.logoDark && (
                  <span class="logo-mark">{logo.name}</span>
                )}
              </>
            );
            return logo.caseStudy ? (
              <a
                class="marquee-cell has-link"
                href={logo.caseStudy}
                aria-hidden={idx >= logos.length}
              >
                {inner}
                <span class="cs-pill">Case Study</span>
              </a>
            ) : (
              <span class="marquee-cell" aria-hidden={idx >= logos.length}>
                {inner}
              </span>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
---
interface LogoCell {
  name: string;
  /** Path to logo file shown in LIGHT mode. */
  logo?: string;
  /** Optional path to logo file shown in DARK mode. If provided, both files
   * are rendered (one hidden by CSS based on data-theme) and the filter/blend
   * treatment is skipped for the theme-matched file. */
  logoDark?: string;
  caseStudy?: string;
}

interface Props {
  label?: string;
  logos?: LogoCell[];
}

const {
  label = "Trusted by over 100 GTM teams",
  logos = [
    { name: "Scrypt", logo: "/logos/scrypt.webp", caseStudy: "/case-studies/scrypt" },
    { name: "HubSpot", logo: "/logos/hubspot.png" },
    { name: "Skribble", logo: "/logos/skribble.webp" },
    { name: "Strategyzer", logo: "/logos/strategyzer.jpg" },
    { name: "Ohalo", logo: "/logos/ohalo.webp", caseStudy: "/case-studies/ohalo" },
    { name: "Bound", logo: "/logos/bound.avif" },
    { name: "Hy.co", logo: "/logos/hyco.png" },
    { name: "Lipdub", logo: "/logos/lipdub.avif" },
    { name: "Adthena", logo: "/logos/adthena.png" },
    { name: "Emlen", logo: "/logos/emlen.svg" },
    { name: "Leostream", logo: "/logos/leostream.webp" },
    { name: "Orca", logo: "/logos/orca.png" },
    { name: "Mybites", logo: "/logos/mybites.svg" },
    { name: "Sysdyne", logo: "/logos/sysdyne.png" },
    { name: "Trawa", logo: "/logos/trawa.png" },
    { name: "Blueprint", logo: "/logos/blueprint.png" },
  ],
} = Astro.props;

const trackLogos = [...logos, ...logos];
---

<section class="marquee-section" aria-label="Clients">
  <div class="marquee-row">
    <div class="marquee-label">{label}</div>
    <div class="marquee">
      <div class="marquee-track">
        {
          trackLogos.map((logo, idx) => {
            const hasBoth = logo.logo && logo.logoDark;
            const inner = (
              <>
                {logo.logo && (
                  <img
                    class:list={[
                      "logo-img",
                      hasBoth && "logo-img-light",
                      hasBoth && "native",
                    ]}
                    src={logo.logo}
                    alt={logo.name}
                    loading="lazy"
                  />
                )}
                {logo.logoDark && (
                  <img
                    class:list={["logo-img", "logo-img-dark", "native"]}
                    src={logo.logoDark}
                    alt={logo.name}
                    loading="lazy"
                  />
                )}
                {!logo.logo && !logo.logoDark && (
                  <span class="logo-mark">{logo.name}</span>
                )}
              </>
            );
            return logo.caseStudy ? (
              <a
                class="marquee-cell has-link"
                href={logo.caseStudy}
                aria-hidden={idx >= logos.length}
              >
                {inner}
                <span class="cs-pill">Case Study</span>
              </a>
            ) : (
              <span class="marquee-cell" aria-hidden={idx >= logos.length}>
                {inner}
              </span>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
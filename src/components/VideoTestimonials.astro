---
interface Testimonial {
  /** Filename in public/testimonials/ or full URL. Optional — placeholder shown when missing. */
  videoSrc?: string;
  name: string;
  title: string;
  company: string;
  quote: string;
  /** Optional thumbnail filename in public/testimonials/ */
  thumbnail?: string;
}

interface Props {
  eyebrow?: string;
  headline?: string;
  testimonials?: Testimonial[];
}

const {
  eyebrow = "What our clients say",
  headline = "In their words.",
  testimonials = [
    {
      name: "Lukas Grabenwöger",
      title: "Co-Founder",
      company: "skilfit",
      quote:
        "We went from 2 meetings a month to 10 meetings per week in just 6 weeks.",
    },
    {
      name: "Ivan Nieuwoudt",
      title: "GTM Engineer",
      company: "warmly",
      quote:
        "We're generating up to $500,000 in pipeline per month using signal-based outreach.",
    },
    {
      name: "Amit Puri",
      title: "Chief Revenue Officer",
      company: "Bound",
      quote: "We 2x'd our pipeline in just 3 months.",
    },
  ],
} = Astro.props;
---

<section class="section video-testimonials-section">
  <div class="container stack-6">
    <span class="eyebrow"
      >{eyebrow}</span
    >
    <h2>{headline}</h2>
    <div class="video-grid">
      {
        testimonials.map((t) => (
          <div class="video-card">
            <button
              class="video-thumb"
              aria-label={`Play testimonial from ${t.name}`}
              data-src={t.videoSrc || ""}
            >
              <span class="video-thumb-fill" />
              <span class="video-play">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M8 5v14l11-7z" />
                </svg>
              </span>
            </button>
            <div class="video-meta">
              <p class="video-quote">{`"${t.quote}"`}</p>
              <div class="video-attribution">
                <span class="video-name">{t.name}</span>
                <span class="video-title">
                  {t.title} · {t.company}
                </span>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
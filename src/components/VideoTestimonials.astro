---
interface Testimonial {
  /** Vimeo URL (any format). Loaded on click. */
  vimeoUrl?: string;
  /** Optional poster image path */
  thumbnail?: string;
  name: string;
  title: string;
  company: string;
  quote: string;
}

interface Props {
  eyebrow?: string;
  headline?: string;
  lead?: string;
  bullets?: string[];
  testimonials?: Testimonial[];
}

const {
  eyebrow = "What our clients say",
  headline = "In their words.",
  lead = "",
  bullets = [],
  testimonials = [
    {
      name: "Lukas Grabenwöger",
      title: "Co-Founder",
      company: "skilfit",
      quote:
        "We went from 2 meetings a month to 10 meetings per week in just 6 weeks.",
      vimeoUrl: "https://vimeo.com/1054119519/a2ff25a184",
    },
    {
      name: "Ivan Nieuwoudt",
      title: "GTM Engineer",
      company: "warmly",
      quote:
        "We're generating up to $500,000 in pipeline per month using signal-based outreach.",
      vimeoUrl: "https://vimeo.com/1126112365/3cd28d2da4",
    },
    {
      name: "Amit Puri",
      title: "Chief Revenue Officer",
      company: "Bound",
      quote: "We 2x'd our pipeline in just 3 months.",
      vimeoUrl: "https://vimeo.com/1054119763/324f7f23a6",
    },
  ],
} = Astro.props;

function parseVimeo(url?: string) {
  if (!url) return { id: undefined, hash: undefined };
  const m = url.match(/vimeo\.com\/(\d+)(?:\/([a-zA-Z0-9]+))?/);
  return { id: m?.[1], hash: m?.[2] };
}

// Fetch Vimeo thumbnails at build time so each facade renders a preview image
// instead of an empty card.
async function getThumb(url?: string): Promise<string> {
  if (!url) return "";
  try {
    const res = await fetch(
      `https://vimeo.com/api/oembed.json?url=${encodeURIComponent(url)}`
    );
    if (!res.ok) return "";
    const data = await res.json();
    return ((data.thumbnail_url as string) || "").replace(/_\d+x\d+/, "_1280");
  } catch (e) {
    return "";
  }
}

const thumbs = await Promise.all(
  testimonials.map((t) => getThumb(t.vimeoUrl))
);
---

<section class="section video-testimonials-section">
  <div class="container stack-6">
    <span class="eyebrow">{eyebrow}</span>
    <h2>{headline}</h2>
    {lead && <p class="lead">{lead}</p>}
    {bullets.length > 0 && (
      <ul class="pain-bullets">{bullets.map((b) => <li>{b}</li>)}</ul>
    )}
    <div class="video-grid">
      {
        testimonials.map((t, i) => {
          const v = parseVimeo(t.vimeoUrl);
          const thumb = thumbs[i];
          return (
            <div class="video-card">
              <button
                class="video-thumb vimeo-facade"
                aria-label={`Play testimonial from ${t.name}`}
                data-vimeo-id={v.id}
                data-vimeo-hash={v.hash}
              >
                <span
                  class="video-thumb-fill"
                  style={thumb
                    ? `background-image: url(${thumb}); background-size: cover; background-position: center;`
                    : undefined}
                />
                <span class="video-play">
                  <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </span>
              </button>
              <div class="video-meta">
                <p class="video-quote">{`"${t.quote}"`}</p>
                <div class="video-attribution">
                  <span class="video-name">{t.name}</span>
                  <span class="video-title">
                    {t.title} · {t.company}
                  </span>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
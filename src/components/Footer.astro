---
import FoundersBlock from "./FoundersBlock.astro";
---

<footer class="footer">
  <div class="container">
    <!-- Top row: brand on left, links on right -->
    <div class="footer-top">
      <a href="/" class="nav-logo" aria-label="Enablement.ch">
        <img src="/logo-black.svg" alt="" class="logo-img logo-img-light" />
        <img src="/logo-white.svg" alt="" class="logo-img logo-img-dark" />
      </a>
      <nav class="footer-links">
        <a href="/case-studies">Clients</a>
        <a href="/book">Book a meeting</a>
      </nav>
    </div>

    <!-- Founders on left, Clay partner badge on right (same row) -->
    <div class="footer-middle">
      <FoundersBlock />
      <a
        href="https://www.clay.com/"
        target="_blank"
        rel="noopener"
        class="clay-badge"
        aria-label="Clay Enterprise Partner"
      >
        <img
          src="/clay-enterprise-partner.png"
          alt="Clay Enterprise Partner"
        />
      </a>
    </div>

    <!-- Thin legal strip at the very bottom -->
    <div class="footer-bottom">
      <span>© {new Date().getFullYear()} Enablement.ch</span>
      <nav class="footer-legal">
        <a href="/privacy">Privacy</a>
        <a href="/gtc">GTC</a>
      </nav>
    </div>
  </div>
</footer>
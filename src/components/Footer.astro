---
import FoundersBlock from "./FoundersBlock.astro";
import PartnerLogos from "./PartnerLogos.astro";
---

<footer class="footer">
  <div class="container">
    <!-- Top row: brand on left, primary links on right -->
    <div class="footer-top">
      <a href="/" class="nav-logo"
        >Enablement<span class="dot">.</span>ch</a
      >
      <nav class="footer-links">
        <a href="/case-studies">Clients</a>
        <a href="/book">Book a meeting</a>
      </nav>
    </div>

    <!-- Founders, compact side-by-side -->
    <FoundersBlock />

    <!-- Partners band -->
    <PartnerLogos />

    <!-- Thin legal strip at the very bottom -->
    <div class="footer-bottom">
      <span>© {new Date().getFullYear()} Enablement.ch</span>
      <nav class="footer-legal">
        <a href="/privacy">Privacy</a>
        <a href="/gtc">GTC</a>
      </nav>
    </div>
  </div>
</footer>
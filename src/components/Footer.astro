---
import FoundersBlock from "./FoundersBlock.astro";
import PartnerLogos from "./PartnerLogos.astro";

const groups = [
  {
    title: "Site",
    links: [
      { href: "/case-studies", label: "Clients" },
      { href: "/book", label: "Schedule meeting" },
    ],
  },
  {
    title: "Legal",
    links: [
      { href: "/gtc", label: "GTC" },
      { href: "/privacy", label: "Privacy" },
    ],
  },
  {
    title: "Contact",
    links: [
      {
        href: "https://www.linkedin.com/company/enablementch",
        label: "LinkedIn",
      },
      { href: "mailto:hello@enablement.ch", label: "hello@enablement.ch" },
    ],
  },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <a href="/" class="nav-logo"
          >Enablement<span class="dot">.</span>ch</a
        >
        <p class="footer-tagline">
          Fractional GTM engineering for B2B teams in DACH.
        </p>
      </div>
      {
        groups.map((g) => (
          <div class="footer-group">
            <h6>{g.title}</h6>
            {g.links.map((l) => (
              <a href={l.href}>{l.label}</a>
            ))}
          </div>
        ))
      }
      <div class="footer-group">
        <FoundersBlock />
      </div>
    </div>

    <PartnerLogos />

    <div class="footer-bottom">
      <span>© {new Date().getFullYear()} Enablement.ch</span>
      <span>Built in DACH.</span>
    </div>
  </div>
</footer>
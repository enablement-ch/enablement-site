---
// Stylized LinkedIn post + revenue chart mock for the Inbound value-prop block.
// v1 placeholder: hand off to design for polish later.
---

<div class="li-mock">
  <article class="li-post">
    <header class="li-post-head">
      <div class="li-avatar" aria-hidden="true">LH</div>
      <div class="li-author">
        <div class="li-name">Lanny M. Heiz</div>
        <div class="li-tagline">Full Sales Pipeline without 3+ BDRs</div>
      </div>
      <div class="li-badge" aria-hidden="true">in</div>
    </header>
    <p class="li-body">
      How we generated <strong>312 meetings</strong> with only 2h of work per
      week (using AI agents)
    </p>
    <div class="li-embed">
      <div class="li-embed-head">
        <span class="li-embed-tab">Deal Stage</span>
        <span class="li-embed-meta">Count · Conversion</span>
      </div>
      <div class="li-bars">
        <div class="li-bar">
          <span class="li-bar-label">Demo</span>
          <span class="li-bar-fill" style="--w:78%"></span>
          <span class="li-bar-pct">68%</span>
        </div>
        <div class="li-bar">
          <span class="li-bar-label">Closed won</span>
          <span class="li-bar-fill" style="--w:42%"></span>
          <span class="li-bar-pct">42%</span>
        </div>
      </div>
    </div>
    <footer class="li-foot">
      <span class="li-reactions">
        <span class="li-react">👍</span>
        <span class="li-react">💡</span>
        <span class="li-react">🔥</span>
        258
      </span>
      <span class="li-comments">· 56 comments</span>
    </footer>
  </article>

  <div class="li-chart">
    <div class="li-chart-head">
      <div>
        <div class="li-chart-title">Closed revenue per month</div>
        <div class="li-chart-legend">
          <span class="legend-dot live"></span>This year
          <span class="legend-dot past"></span>Last year
        </div>
      </div>
      <div class="li-chart-figure">$100K</div>
    </div>
    <svg class="li-chart-svg" viewBox="0 0 320 100" preserveAspectRatio="none" aria-hidden="true">
      <defs>
        <linearGradient id="liFill" x1="0" x2="0" y1="0" y2="1">
          <stop offset="0%" stop-color="var(--color-accent)" stop-opacity="0.35" />
          <stop offset="100%" stop-color="var(--color-accent)" stop-opacity="0" />
        </linearGradient>
      </defs>
      <path
        d="M0,80 L40,76 L80,72 L120,64 L160,52 L200,40 L240,28 L280,18 L320,10 L320,100 L0,100 Z"
        fill="url(#liFill)"
      ></path>
      <polyline
        points="0,80 40,76 80,72 120,64 160,52 200,40 240,28 280,18 320,10"
        fill="none"
        stroke="var(--color-accent)"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      ></polyline>
      <polyline
        points="0,90 40,88 80,86 120,82 160,78 200,72 240,66 280,60 320,54"
        fill="none"
        stroke="var(--color-border-strong)"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-dasharray="3 4"
      ></polyline>
    </svg>
  </div>

  <span class="li-spark sp1" aria-hidden="true">✦</span>
  <span class="li-spark sp2" aria-hidden="true">✦</span>
</div>

<style>
  .li-mock {
    position: relative;
    width: 100%;
    max-width: 460px;
    margin: 0 auto;
    padding: var(--space-6) var(--space-5);
  }
  .li-post {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  }
  .li-post-head {
    display: grid;
    grid-template-columns: 40px 1fr auto;
    gap: var(--space-3);
    align-items: center;
    margin-bottom: var(--space-4);
  }
  .li-avatar {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    background: var(--color-accent);
    color: var(--color-accent-on);
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    display: grid;
    place-items: center;
    letter-spacing: 0.04em;
  }
  .li-name {
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1.2;
    font-size: 15px;
  }
  .li-tagline {
    color: var(--color-muted);
    font-size: 12px;
    font-family: var(--font-mono);
  }
  .li-badge {
    width: 24px;
    height: 24px;
    border-radius: var(--radius-xs);
    background: #0a66c2;
    color: #fff;
    display: grid;
    place-items: center;
    font-weight: 800;
    font-size: 12px;
    font-style: italic;
  }
  .li-body {
    color: var(--color-heading);
    font-size: 15px;
    line-height: 1.45;
    margin: 0 0 var(--space-4);
  }
  .li-body strong {
    color: var(--color-heading);
    font-weight: 700;
  }
  .li-embed {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface-raised);
  }
  .li-embed-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-3);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    text-transform: uppercase;
  }
  .li-bars {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .li-bar {
    display: grid;
    grid-template-columns: 88px 1fr 40px;
    align-items: center;
    gap: var(--space-3);
    font-size: 12px;
    color: var(--color-body);
  }
  .li-bar-label {
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
  }
  .li-bar-fill {
    height: 14px;
    border-radius: var(--radius-xs);
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-hover));
    width: var(--w);
    display: block;
  }
  .li-bar-pct {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-heading);
    text-align: right;
  }
  .li-foot {
    display: flex;
    justify-content: flex-start;
    gap: var(--space-3);
    margin-top: var(--space-4);
    color: var(--color-muted);
    font-size: 12px;
    font-family: var(--font-mono);
  }
  .li-react {
    margin-right: 2px;
    font-size: 12px;
  }
  .li-chart {
    position: relative;
    margin: -28px 0 0 auto;
    width: 78%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    z-index: 2;
  }
  .li-chart-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-3);
  }
  .li-chart-title {
    font-weight: 600;
    color: var(--color-heading);
    font-size: 14px;
    line-height: 1.3;
  }
  .li-chart-legend {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-muted);
  }
  .legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    display: inline-block;
    margin-right: 2px;
  }
  .legend-dot.live { background: var(--color-accent); }
  .legend-dot.past { background: var(--color-border-strong); }
  .li-chart-figure {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-heading);
    font-size: 18px;
    letter-spacing: -0.01em;
  }
  .li-chart-svg {
    width: 100%;
    height: 90px;
    display: block;
  }
  .li-spark {
    position: absolute;
    color: var(--color-accent);
    font-size: 18px;
    line-height: 1;
  }
  .li-spark.sp1 { top: 38%; right: -6px; }
  .li-spark.sp2 { bottom: 6%; left: 12%; opacity: 0.7; font-size: 14px; }
</style>
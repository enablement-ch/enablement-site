---
interface QA {
  q: string;
  a: string;
}

interface Props {
  eyebrow?: string;
  headline?: string;
  questions?: QA[];
}

const {
  eyebrow = "FAQ",
  headline = "Common questions.",
  questions = [
    {
      q: "How are you different from other agencies?",
      a: "Most agencies keep you dependent on them by design — black-box process, no visibility, no exit. We build a system you own. We run it for you, but you always understand what's happening and why. When you're ready to take it over, you can. No lock-in.",
    },
    {
      q: "How much do I need to invest?",
      a: "Most customers invest between $6–15k with us for 3–12 months, depending on their goals. We'll give you the exact amount during our GTM Session — no hourly billing, no hidden costs, no surprises.",
    },
    {
      q: "How fast can we be live?",
      a: "The first campaigns are live within 3 weeks. After that we optimize, expand and scale the setup.",
    },
    {
      q: "Should I not hire a GTM Engineer in-house instead?",
      a: "Sometimes the answer is yes. We've turned down engagements where hiring was clearly the right move. The honest take: a fractional GTM team gets you 99% of the value at 50% of the cost in 30% of the time. Most customers get us to build the system and then transfer it over to someone internal.",
    },
    {
      q: "What happens in the GTM Session?",
      a: "We have a look at your current efforts to create a full sales pipeline. Based on that, we identify the biggest levers you need to pull to scale your revenue to the next stage. This roadmap is custom-made just for you. If we both agree it's the right way to go, we make you an offer. Only 39% of companies even get an offer to work with us.",
    },
  ],
} = Astro.props;
---

<section class="section faq-section">
  <div class="container stack-6">
    <span class="eyebrow"
      >{eyebrow}</span
    >
    <h2>{headline}</h2>
    <div class="faq-list">
      {
        questions.map((qa, idx) => (
          <details class="faq-item">
            <summary class="faq-summary">
              <span class="faq-q">
                <span class="faq-num">
                  {String(idx + 1).padStart(2, "0")}
                </span>
                {qa.q}
              </span>
              <span class="faq-toggle" aria-hidden="true" />
            </summary>
            <div class="faq-body">
              <p>{qa.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import MarqueeLogoWall from "../components/MarqueeLogoWall.astro";
import VideoTestimonials from "../components/VideoTestimonials.astro";
import PainBlock from "../components/PainBlock.astro";
import FAQ from "../components/FAQ.astro";
import Workflow from "../components/Workflow.astro";
import LinkedInMock from "../components/visuals/LinkedInMock.astro";
import BeforeAfterEmail from "../components/visuals/BeforeAfterEmail.astro";
import OperatingPipeline from "../components/visuals/OperatingPipeline.astro";
import AllboundOrg from "../components/visuals/AllboundOrg.astro";
---

<BaseLayout>
  <!-- 01 Hero with VSL -->
  <Hero />

  <!-- 02 Marquee logos -->
  <MarqueeLogoWall />

  <!-- 03 Video testimonials -->
  <VideoTestimonials />

  <!-- 04 Value props × 3 -->
  <section class="section pain-section">
    <div class="container stack-6">
      <span class="eyebrow">What we build</span>
      <h2>Three systems. <span class="italic-accent">One operating layer.</span></h2>
      <p>
        We don't sell strategy or playbooks. We install three systems that turn
        your tools into outbound, inbound, and a RevOps spine that wires them
        together.
      </p>
    </div>

    <div class="pain-stack">
      <div class="container">
        <PainBlock
          eyebrow="STACK"
          headline="Connect every GTM tool into one automated stack."
          lead="Your stack runs as one engine, not 12 disconnected tabs."
          bullets={[
            "Real-time enrichment and routing across HubSpot, Clay, Apollo, Outreach",
            "Claude Code agents that prep AEs for discovery, draft follow-ups, run newsletters",
            "The internal systems we built to run our own GTM, installed in yours",
          ]}
          ctaLabel="See how we glue the stack"
          ctaHref="/case-studies"
        >
          <AllboundOrg />
        </PainBlock>
      </div>
    </div>

    <div class="pain-stack">
      <div class="container">
        <PainBlock
          eyebrow="INBOUND"
          headline="Turn your founder's LinkedIn into a pipeline channel."
          lead="Three posts a week becomes signal you can sell on."
          bullets={[
            "Ghost-written thought leader content shipped 3x per week",
            "Engagement tracking that scores every commenter and viewer",
            "ICP-fit engagers auto-routed into personalized outbound",
          ]}
          ctaLabel="See our inbound engine"
          ctaHref="/case-studies"
          reverse={true}
        >
          <LinkedInMock />
        </PainBlock>
      </div>
    </div>

    <div class="pain-stack">
      <div class="container">
        <PainBlock
          eyebrow="OUTBOUND"
          headline="Send outreach only when buyers are in-market."
          lead="Outbound that books, because it triggers on real intent."
          bullets={[
            "Triggers on real intent: hiring, funding, tech adoption, content engagement",
            "AI personalization with operator review - 1:1 quality at 1:100 volume",
            "Wired into your CRM: signals route to Slack, alerts to AEs, replies tracked back",
          ]}
          ctaLabel="See our outbound engine"
          ctaHref="/case-studies"
        >
          <BeforeAfterEmail />
        </PainBlock>
      </div>
    </div>
  </section>

  <!-- 05 FAQ -->
  <FAQ />

  <!-- 06 Final CTA -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-inner">
        <h2>30 minutes. <span class="italic-accent">No deck.</span></h2>
        <p class="lead">
          We map your current pipeline, identify the highest-leverage system to
          build first, and tell you whether we're a fit. If we're not, we'll
          point you to who is.
        </p>
        <div class="hero-actions" style="justify-content:center">
          <a href="/book" class="btn btn-accent btn-md">Schedule meeting</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import MarqueeLogoWall from "../components/MarqueeLogoWall.astro";
import VideoTestimonials from "../components/VideoTestimonials.astro";
import PainBlock from "../components/PainBlock.astro";
import FAQ from "../components/FAQ.astro";
import Workflow from "../components/Workflow.astro";
import LinkedInMock from "../components/visuals/LinkedInMock.astro";
import BeforeAfterEmail from "../components/visuals/BeforeAfterEmail.astro";
import OperatingPipeline from "../components/visuals/OperatingPipeline.astro";
import AllboundOrg from "../components/visuals/AllboundOrg.astro";
---

<BaseLayout>
  <!-- 01 Hero with VSL -->
  {/* secondary CTA hidden for soft launch — restore default "See client work → /case-studies" when case studies relaunch */}
  <Hero secondaryLabel="" secondaryHref="" />

  <!-- 02 Marquee logos -->
  <MarqueeLogoWall />

  <!-- 03 Video testimonials -->
  <VideoTestimonials />

  <!-- 04 Value props × 3 -->
  <section class="section pain-section">
    <div class="container stack-6">
      <h2>Combine Outbound and Inbound into an <span class="italic-accent">Allbound Engine</span></h2>
      <p class="lead">Inbound earns trust. Outbound triggers on intent. The connected stack makes both compound.</p>
    </div>

    <div class="pain-stack">
      <div class="container">
        <PainBlock
          eyebrow="Allbound Foundation"
          headline="Connect every GTM tool into one automated stack."
          lead="Your stack runs as one engine, not 12 disconnected tools."
          bullets={[
            "Connect your tool stack in one system and never export & import a CSV file again.",
            "Identify, score and route leads to the right rep",
            "Enrich any data point you need and act on it in minutes not hours or even days",
          ]}
        >
          <AllboundOrg />
        </PainBlock>
      </div>
    </div>

    <div class="pain-stack">
      <div class="container">
        <PainBlock
          eyebrow="Outbound Alone Falls Flat"
          headline="Turn Content into Sales Pipeline"
          lead="Buyers buy from people they already trust."
          bullets={[
            "Create content that people trust instead of AI slop they scroll past.",
            "Build a loyal audience and convert them into inbound leads",
            "Reach out to the people that already know, like and trust you.",
          ]}
          reverse={true}
        >
          <LinkedInMock />
        </PainBlock>
      </div>
    </div>

    <div class="pain-stack">
      <div class="container">
        <PainBlock
          eyebrow="Inbound Alone is Slow"
          headline="Put your outreach on autopilot"
          lead="Outreach that books, because it triggers on real intent."
          bullets={[
            "Research any prospect in seconds instead of doing it manually",
            "Personalised messages that sound like you wrote them 1:1 - at a 1:1000 scale",
            "Deploy AI Agents that find high-intent leads, personalise the message and fill your calendar with qualified meetings.",
          ]}
        >
          <BeforeAfterEmail />
        </PainBlock>
      </div>
    </div>
  </section>

  <!-- 05 FAQ -->
  <FAQ />

  <!-- 06 Final CTA -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-inner">
        <h2>
          Ready to turn your tools into <span class="italic-accent">a GTM system?</span>
        </h2>
        <p class="lead">
          Book a 30-min GTM session. We'll audit your pipeline, find the
          highest-leverage action to take, and tell you whether we're a fit.
          If we're not, we'll point you to who is.
        </p>
        <div class="hero-actions" style="justify-content:center">
          <a href="/book" class="btn btn-accent btn-md">Book a GTM session</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
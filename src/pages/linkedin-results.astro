---
import BaseLayout from "../layouts/BaseLayout.astro";
import VideoTestimonials from "../components/VideoTestimonials.astro";

const impressions = [
  "/linkedin-results/img/impressions/impressions-2.5m.png",
  "/linkedin-results/img/impressions/impressions-2.49m.png",
  "/linkedin-results/img/impressions/engagement-37k.png",
  "/linkedin-results/img/impressions/followers-20k.png",
  "/linkedin-results/img/impressions/small-account-spike.png",
  "/linkedin-results/img/impressions/top-posts.png",
];

const dms = [
  "/linkedin-results/img/dms/dm-carolyn.png",
  "/linkedin-results/img/dms/dm-jennifer.png",
  "/linkedin-results/img/dms/dm-arman.png",
  "/linkedin-results/img/dms/dm-jake.png",
  "/linkedin-results/img/dms/dm-enrico.png",
];

const authorityBullets = [
  "We shape the founder's unique POV, expertise, and stories into content that makes buyers stop scrolling and pay attention.",
  "We position the founder around the problems your buyers already care about.",
  'We make buyers think, "these people understand my problem - and probably know how to solve it."',
];

const signalsBullets = [
  "Track the signals your content creates: likes, comments, profile views, clicks, saves, DMs, and replies.",
  "Filter for the people and companies that actually fit your ICP.",
  "Start warm conversations that turn into meetings.",
];
---

<BaseLayout
  title="LinkedIn Results · Enablement.ch"
  description="Real results from founder-led LinkedIn content systems: reach, buying signals, DMs, meetings, and pipeline."
  noindex={true}
>
  <!-- HERO -->
  <header class="hero">
    <div class="container stack-6" style="padding-block: var(--space-10)">
      <span class="eyebrow"><span class="num">Proof</span><span class="sep">/</span>How it works</span>
      <h1>Results from <span class="italic-accent">founder-led content systems</span> we've built</h1>
      <p class="lead">
        We turn founder expertise into content that builds trust on LinkedIn -
        then turn that trust and attention into qualified sales conversations.
      </p>
      <p class="hero-caption">
        Below are real screenshots from the LinkedIn content systems we've built:
        reach, engagement, buying signals, DMs, meetings, and pipeline outcomes.
      </p>
    </div>
  </header>

  <!-- 01 AUTHORITY -->
  <section class="section scrolly" id="authority">
    <div class="container">
      <span class="eyebrow"><span class="num">01</span><span class="sep">/</span>Build Authority</span>
      <div class="scrolly-concept-mobile">
        <h3>Content that earns attention and <span class="italic-accent">trust.</span></h3>
        <p class="lead">Most LinkedIn content feels generic or obviously written by AI. We turn the founder's knowledge, stories, and hard-won insights into content buyers actually care about.</p>
        <ul class="pain-bullets">{authorityBullets.map((b) => <li>{b}</li>)}</ul>
      </div>
      <div class="scrolly-grid">
        <aside class="scrolly-aside">
          <div class="scrolly-sticky">
            <h3>Content that earns attention and <span class="italic-accent">trust.</span></h3>
            <p class="lead">Most LinkedIn content feels generic or obviously written by AI. We turn the founder's knowledge, stories, and hard-won insights into content buyers actually care about.</p>
            <ul class="pain-bullets">{authorityBullets.map((b) => <li>{b}</li>)}</ul>
          </div>
        </aside>
        <div class="scrolly-steps">
          {impressions.map((src) => (
            <div class="scrolly-step">
              <figure class="scrolly-card"><img loading="lazy" src={src} alt="Reach metric" /></figure>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 02 INBOUND -->
  <section class="section scrolly" id="inbound">
    <div class="container">
      <span class="eyebrow"><span class="num">02</span><span class="sep">/</span>Buying Signals</span>
      <div class="scrolly-concept-mobile">
        <h3>Turn attention into <span class="italic-accent">conversations.</span></h3>
        <p class="lead">Likes, comments, and profile views don't pay the bills. But they are the signals we track to see who is interested, who fits your ICP, and where there is a reason to start a warm conversation.</p>
        <ul class="pain-bullets">{signalsBullets.map((b) => <li>{b}</li>)}</ul>
      </div>
      <div class="scrolly-grid">
        <aside class="scrolly-aside">
          <div class="scrolly-sticky">
            <h3>Turn attention into <span class="italic-accent">conversations.</span></h3>
            <p class="lead">Likes, comments, and profile views don't pay the bills. But they are the signals we track to see who is interested, who fits your ICP, and where there is a reason to start a warm conversation.</p>
            <ul class="pain-bullets">{signalsBullets.map((b) => <li>{b}</li>)}</ul>
          </div>
        </aside>
        <div class="scrolly-steps">
          {dms.map((src) => (
            <div class="scrolly-step">
              <figure class="scrolly-card"><img loading="lazy" src={src} alt="Inbound message" /></figure>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 03 PIPELINE — proof videos (reused homepage component) -->
  <VideoTestimonials
    eyebrow="03 / Pipeline"
    headline="Turning trust into pipeline."
    lead="The point is not to post content. The point is to build trust before the sales call, create more qualified conversations, and turn those conversations into pipeline."
  />

  <!-- FINAL CTA -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-inner">
        <h2>Want this for <span class="italic-accent">your company?</span></h2>
        <p class="lead">
          Book a 30-min GTM session. We'll audit your pipeline, find the
          highest-leverage action, and tell you whether we're a fit.
        </p>
        <div class="hero-actions" style="justify-content:center">
          <a href="/book" class="btn btn-accent btn-md">Book a GTM session</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- hero ---- */
  .hero-caption {
    color: var(--color-muted);
    max-width: 60ch;
  }

  /* ---- image lightbox ---- */
  .img-lightbox {
    position: fixed; inset: 0; z-index: 60; display: none;
    align-items: center; justify-content: center; padding: var(--space-6);
    background: rgba(15, 18, 23, 0.92); cursor: zoom-out;
  }
  .img-lightbox.open { display: flex; }
  .img-lightbox img { max-width: 92vw; max-height: 90vh; border-radius: var(--radius-md); box-shadow: var(--shadow-lg); }

  /* ---- scrollytelling ---- */
  section.scrolly { padding-block: var(--space-8); }
  @media (min-width: 1024px) {
    section.scrolly { padding-block: var(--space-10); }
  }

  .scrolly .eyebrow { margin-bottom: var(--space-7); display: inline-flex; }

  .scrolly-grid { display: grid; grid-template-columns: 1fr; gap: 0; }
  .scrolly-aside { display: none; }
  .scrolly-concept-mobile { margin-bottom: var(--space-6); }
  .scrolly-concept-mobile h3 { font-size: var(--font-size-h4); }
  .scrolly-concept-mobile p { margin-top: var(--space-3); }

  @media (min-width: 1024px) {
    .scrolly-grid { grid-template-columns: 0.82fr 1.18fr; gap: var(--space-9); }
    .scrolly-aside { display: block; }
    .scrolly-concept-mobile { display: none; }
  }

  .scrolly-sticky {
    position: sticky; top: 12vh;
    display: flex; flex-direction: column;
  }
  .scrolly-sticky h3 { font-size: var(--font-size-h2); letter-spacing: -0.025em; }
  .scrolly-sticky p { margin-top: var(--space-4); max-width: 32ch; }
  .scrolly-sticky .pain-bullets,
  .scrolly-concept-mobile .pain-bullets { margin-top: var(--space-6); }

  .scrolly-step { padding: var(--space-3) 0; }
  @media (min-width: 1024px) {
    /* Plain evenly-spaced stack. The headline is pinned near the top (not
       centered), so screenshots just scroll past it - no lead-in/out padding,
       no per-step min-height, no dead space between sections. Equal gap keeps
       the spacing identical regardless of how tall each screenshot is. */
    .scrolly-steps {
      display: flex;
      flex-direction: column;
      gap: var(--space-9);
    }
    .scrolly-step { min-height: 0; padding: 0; }
  }

  .scrolly-card {
    margin: 0; width: 100%; overflow: hidden; cursor: zoom-in;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xs);
    transition: opacity var(--motion-duration-base) var(--motion-ease-standard),
                transform var(--motion-duration-base) var(--motion-ease-standard),
                box-shadow var(--motion-duration-base) var(--motion-ease-standard);
  }
  .scrolly-card img { display: block; width: 100%; height: auto; }

  @media (min-width: 1024px) {
    .scrolly-step .scrolly-card { opacity: 0.4; transform: scale(0.98); }
    .scrolly-step.is-active .scrolly-card { opacity: 1; transform: scale(1); box-shadow: var(--shadow-lg); }
  }
</style>

<div class="img-lightbox" id="imgLightbox"><img src="" alt="" /></div>

<script is:inline>
  (function () {
    // Active-step highlight
    document.querySelectorAll(".scrolly").forEach(function (section) {
      var steps = Array.prototype.slice.call(section.querySelectorAll(".scrolly-step"));
      if (steps[0]) steps[0].classList.add("is-active");
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            var idx = steps.indexOf(e.target);
            steps.forEach(function (s, i) { s.classList.toggle("is-active", i === idx); });
          }
        });
      }, { rootMargin: "-45% 0px -45% 0px", threshold: 0 });
      steps.forEach(function (s) { io.observe(s); });
    });

    // Image lightbox
    var lb = document.getElementById("imgLightbox");
    var lbImg = lb && lb.querySelector("img");
    document.querySelectorAll(".scrolly-card").forEach(function (card) {
      card.addEventListener("click", function () {
        var img = card.querySelector("img");
        if (!img || !lb) return;
        lbImg.src = img.src;
        lb.classList.add("open");
      });
    });
    if (lb) lb.addEventListener("click", function () { lb.classList.remove("open"); });
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && lb) lb.classList.remove("open");
    });
  })();
</script>